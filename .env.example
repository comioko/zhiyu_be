# 知域后端 Docker Compose 环境变量模板
# 复制为 .env 并填入真实值：cp .env.example .env
# .env 已在 .gitignore，不会被提交

# ============================================
# 服务端口
# ============================================
SERVER_PORT=8080

# ============================================
# MySQL
# ============================================
DB_URL=jdbc:mysql://127.0.0.1:3306/zhiguang?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=rootpass123
MYSQL_DATABASE=zhiguang
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=rootpass123

# ============================================
# Redis
# ============================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# Kafka
# ============================================
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_LISTENER_AUTO_STARTUP=false

# ============================================
# Elasticsearch
# ============================================
ES_URIS=http://127.0.0.1:9200
ES_USERNAME=elastic
ES_PASSWORD=
ES_PORT=9200

# ============================================
# AI 服务（DeepSeek + 通义千问 Embedding）
# ============================================
# 留空：AI 自动装配失败 → RAG/AI controller 整体不注册（返回 404）
# 填入：AI 模块启用
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode

# ============================================
# 阿里云 OSS
# ============================================
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=comioko-zhg
OSS_PUBLIC_DOMAIN=

# ============================================
# 邮件（QQ 邮箱 SMTP）
# ============================================
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ============================================
# Canal（binlog 订阅，默认关闭）
# ============================================
CANAL_ENABLED=false
CANAL_HOST=127.0.0.1
CANAL_PORT=11111
CANAL_DESTINATION=example
CANAL_USERNAME=canal
CANAL_PASSWORD=
